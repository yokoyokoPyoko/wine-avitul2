+        MultiByteToWideChar(CP_UTF8, 0, label, -1, labelW, ARRAY_SIZE(labelW));
+
+        len = 0;
+        for (i = 0; labelW[i] && len < (int)(ARRAY_SIZE(label_sanitized) - 1); i++)
+        {
+            if (labelW[i] != L'\\' && labelW[i] != L'/' && labelW[i] != L':' &&
+                labelW[i] != L'*' && labelW[i] != L'?' && labelW[i] != L'"' &&
+                labelW[i] != L'<' && labelW[i] != L'>' && labelW[i] != L'|')
+                label_sanitized[len++] = labelW[i];
+        }
+        label_sanitized[len] = 0;
+
+        expected_labels[bm_count] = SHAlloc((lstrlenW(label_sanitized) + 1) * sizeof(WCHAR));
+        expected_targets[bm_count] = SHAlloc((lstrlenW(target) + 1) * sizeof(WCHAR));
+        if (!expected_labels[bm_count] || !expected_targets[bm_count])
+        {
+            SHFree(expected_labels[bm_count]);
+            SHFree(expected_targets[bm_count]);
+            continue;
+        }
+        lstrcpyW(expected_labels[bm_count], label_sanitized);
+        lstrcpyW(expected_targets[bm_count], target);
+        bm_count++;
+    }
+    fclose(f);
+
+    /* Phase 2: delete stale .lnk files (only those created by us pointing to Z:\) */
+    {
+        WCHAR search_path[MAX_PATH];
+        HANDLE hFind;
+        WIN32_FIND_DATAW find_data;
+
+        swprintf(search_path, ARRAY_SIZE(search_path), L"%s\\*.lnk", fav_path);
+        hFind = FindFirstFileW(search_path, &find_data);
+        if (hFind != INVALID_HANDLE_VALUE)
+        {
+            do
+            {
+                WCHAR full_path[MAX_PATH];
+                int match = 0;
+
+                swprintf(full_path, ARRAY_SIZE(full_path), L"%s\\%s", fav_path, find_data.cFileName);
+
+                /* Check if this .lnk filename matches any current bookmark */
+                {
+                    WCHAR *dot = wcsrchr(find_data.cFileName, L'.');
+                    if (dot) *dot = 0;
+                    for (i = 0; i < bm_count; i++)
+                    {
+                        if (!lstrcmpiW(find_data.cFileName, expected_labels[i]))
+                        {
+                            match = 1;
+                            break;
+                        }
+                    }
+                    if (dot) *dot = L'.';
+                }
+
+                if (!match)
+                {
+                    /* Not in current bookmarks. Check if it's one of ours (target Z:\) */
+                    IShellLinkW *psl_check;
+                    hr = CoCreateInstance(&CLSID_ShellLink, NULL, CLSCTX_INPROC_SERVER,
+                                           &IID_IShellLinkW, (void**)&psl_check);
+                    if (SUCCEEDED(hr))
+                    {
+                        IPersistFile *ppf_check;
+                        hr = IShellLinkW_QueryInterface(psl_check, &IID_IPersistFile, (void**)&ppf_check);
+                        if (SUCCEEDED(hr))
+                        {
+                            if (SUCCEEDED(IPersistFile_Load(ppf_check, full_path, 0)))
+                            {
+                                WCHAR chk_path[MAX_PATH];
+                                if (SUCCEEDED(IShellLinkW_GetPath(psl_check, chk_path, MAX_PATH, NULL, 0)))
+                                {
+                                    if (!wcsncmp(chk_path, L"Z:\\", 3))
+                                    {
+                                        DeleteFileW(full_path);
+                                        TRACE("Deleted stale bookmark .lnk: %s\n", debugstr_w(full_path));
+                                    }
+                                }
+                            }
+                            IPersistFile_Release(ppf_check);
+                        }
+                        IShellLinkW_Release(psl_check);
+                    }
+                }
+            } while (FindNextFileW(hFind, &find_data));
+            FindClose(hFind);
+        }
+    }
+
+    /* Phase 3: create/update .lnk files */
+    for (i = 0; i < bm_count; i++)
+    {
+        WCHAR label_sanitized[MAX_PATH], lnk_path[MAX_PATH];
+        IShellLinkW *psl;
+        IPersistFile *ppf;
+
+        lstrcpyW(label_sanitized, expected_labels[i]);
+        swprintf(lnk_path, ARRAY_SIZE(lnk_path), L"%s\\%s.lnk", fav_path, label_sanitized);
+
+        hr = CoCreateInstance(&CLSID_ShellLink, NULL, CLSCTX_INPROC_SERVER,
+                               &IID_IShellLinkW, (void**)&psl);
+        if (FAILED(hr)) continue;
+
+        {
+            WCHAR target_full[MAX_PATH + 10], *p2;
+            LPITEMIDLIST pidl;
+            swprintf(target_full, ARRAY_SIZE(target_full), L"Z:%s", expected_targets[i]);
+            for (p2 = target_full; *p2; p2++) if (*p2 == L'/') *p2 = L'\\';
+            pidl = ILCreateFromPathW(target_full);
+            if (pidl)
+            {
+                IShellLinkW_SetIDList(psl, pidl);
+                ILFree(pidl);
+            }
+            IShellLinkW_SetPath(psl, target_full);
+        }
+
+        hr = IShellLinkW_QueryInterface(psl, &IID_IPersistFile, (void**)&ppf);
+        if (SUCCEEDED(hr))
+        {
+            IPersistFile_Save(ppf, lnk_path, TRUE);
+            IPersistFile_Release(ppf);
+        }
+        IShellLinkW_Release(psl);
+    }
+
+    /* Phase 4: clean up */
+    for (i = 0; i < bm_count; i++)
+    {
+        SHFree(expected_labels[i]);
+        SHFree(expected_targets[i]);
+    }
+#undef MAX_BOOKMARKS
+}
