+/**************************************************************************
+ * GTK bookmarks → Favorites .lnk creation
+ */
+
+static void url_decode_inplace(char *str)
+{
+    char *src = str, *dst = str;
+    while (*src)
+    {
+        if (src[0] == '%' && isxdigit(src[1]) && isxdigit(src[2]))
+        {
+            unsigned int val;
+            sscanf(src + 1, "%02x", &val);
+            *dst++ = (char)val;
+            src += 3;
+        }
+        else
+        {
+            *dst++ = *src++;
+        }
+    }
+    *dst = 0;
+}
+
+static void sync_gtk_bookmarks_to_favorites(void)
+{
+#define MAX_BOOKMARKS 64
+    char username[128], bm_file[512], line[4096];
+    WCHAR fav_path[MAX_PATH], target[MAX_PATH];
+    WCHAR *expected_labels[MAX_BOOKMARKS];
+    WCHAR *expected_targets[MAX_BOOKMARKS];
+    int bm_count = 0;
+    FILE *f;
+    HRESULT hr;
+    DWORD size;
+    int i;
+
+    size = sizeof(username);
+    if (!GetUserNameA(username, &size))
+    {
+        TRACE("GetUserNameA failed\n");
+        return;
+    }
+
+    hr = SHGetFolderPathW(NULL, CSIDL_FAVORITES, NULL, 0, fav_path);
+    if (FAILED(hr))
+    {
+        TRACE("SHGetFolderPathW(FAVORITES) failed 0x%08lx\n", hr);
+        return;
+    }
+
+    snprintf(bm_file, sizeof(bm_file), "/home/%s/.config/gtk-3.0/bookmarks", username);
+    f = fopen(bm_file, "r");
+    if (!f)
+    {
+        TRACE("Could not open %s\n", bm_file);
+        return;
+    }
+
+    /* Phase 1: read all bookmarks and collect expected labels + targets */
+    while (bm_count < MAX_BOOKMARKS && fgets(line, sizeof(line), f))
+    {
+        char *space, *unix_path, *label;
+        WCHAR labelW[256], label_sanitized[256];
+        int len;
+
+        line[strcspn(line, "\r\n")] = 0;
+        if (!*line) continue;
+
+        space = strchr(line, ' ');
+        if (space)
+        {
+            *space = 0;
+            unix_path = line;
+            label = space + 1;
+        }
+        else
+        {
+            unix_path = line;
+            label = strrchr(unix_path, '/');
+            if (label) label++;
+            if (!label || !*label) label = unix_path;
+            if (strncmp(unix_path, "file://", 7) == 0 && strncmp(label, "file://", 7) == 0)
+                label = unix_path + 7;
+        }
+
+        if (strncmp(unix_path, "file://", 7) == 0)
+            unix_path += 7;
+        else
+            continue;
