+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <wchar.h>
+#include <unistd.h>
+#include <sys/wait.h>
+#include <windows.h>
+
+static char *strdup_utf8(const WCHAR *str)
+{
+    char *ret;
+    int len = WideCharToMultiByte(CP_UTF8, 0, str, -1, NULL, 0, NULL, NULL);
+    if (!len) return NULL;
+    ret = malloc(len);
+    if (ret) WideCharToMultiByte(CP_UTF8, 0, str, -1, ret, len, NULL, NULL);
+    return ret;
+}
+
+static WCHAR *strdup_wide(const char *str)
+{
+    WCHAR *ret;
+    int len = MultiByteToWideChar(CP_UTF8, 0, str, -1, NULL, 0);
+    if (!len) return NULL;
+    ret = malloc(len * sizeof(WCHAR));
+    if (ret) MultiByteToWideChar(CP_UTF8, 0, str, -1, ret, len);
+    return ret;
+}
+
+/* Replace all ';' with ' ' in a string, in place. */
+static void replace_semicolons_with_spaces(char *str)
+{
+    for (; *str; str++)
+        if (*str == ';') *str = ' ';
+}
+
+/* Check if a UTF-8 path looks like a Windows path (starts with drive letter + colon). */
+static int is_windows_path(const char *path)
+{
+    return (strlen(path) >= 2 && path[1] == ':');
+}
+
+/* Convert Windows path to Unix path using Wine API.
+ * Returns malloc'd string, or NULL on failure. */
+static char *win_to_unix_path(const WCHAR *win_path)
+{
+    char *unix_path = wine_get_unix_file_name(win_path);
+    if (!unix_path) return NULL;
+    char *result = strdup(unix_path);
+    HeapFree(GetProcessHeap(), 0, unix_path);
+    return result;
+}
+
+/* Convert Unix path to Windows path using Wine API.
+ * Returns malloc'd WCHAR string, or NULL on failure. */
+static WCHAR *unix_to_win_path(const char *unix_path)
+{
+    WCHAR *win_path = wine_get_dos_file_name(unix_path);
+    if (!win_path) return NULL;
+    WCHAR *result = wcsdup(win_path);
+    HeapFree(GetProcessHeap(), 0, win_path);
+    return result;
+}
+
+static char *run_zenity(char **zenity_argv)
+{
+    int pipefd[2];
+    pid_t pid;
+    char buf[4096];
+    ssize_t len;
+    int status;
+
+    if (pipe(pipefd) == -1) return NULL;
+    if (zenity_argv[0] == NULL) { close(pipefd[0]); close(pipefd[1]); return NULL; }
+
+    pid = fork();
+    if (pid == -1)
+    {
+        close(pipefd[0]);
+        close(pipefd[1]);
+        return NULL;
+    }
+
+    if (pid == 0)
+    {
+        close(pipefd[0]);
+        dup2(pipefd[1], STDOUT_FILENO);
+        close(pipefd[1]);
+        execvp(zenity_argv[0], zenity_argv);
+        _exit(1);
+    }
+
+    close(pipefd[1]);
+    len = read(pipefd[0], buf, sizeof(buf) - 1);
+    close(pipefd[0]);
+
+    waitpid(pid, &status, 0);
+
+    if (len <= 0 || !WIFEXITED(status) || WEXITSTATUS(status) != 0)
+        return NULL;
+
+    buf[len] = '\0';
+    while (len > 0 && (buf[len-1] == '\n' || buf[len-1] == '\r'))
+        buf[--len] = '\0';
+    if (len == 0) return NULL;
+    return strdup(buf);
+}
+
+int wmain(int argc, WCHAR *argv_w[])
+{
+    char *zenity_argv[64];
+    int n = 2, i;
+    char *result;
+    WCHAR temp_path[MAX_PATH];
+    int needs_filter_convert = 0;
+
+    zenity_argv[0] = (char *)"/usr/bin/zenity";
+    zenity_argv[1] = (char *)"--file-selection";
+
+    for (i = 1; i < argc && n < 60; i++)
+    {
+        char *arg = strdup_utf8(argv_w[i]);
+        if (!arg) continue;
+
+        if (!lstrcmpW(argv_w[i], L"--open") || !lstrcmpW(argv_w[i], L"--save"))
+        {
+            free(arg);
+            continue;
+        }
+        if (!lstrcmpW(argv_w[i], L"--folder"))
+        {
+            free(arg);
+            zenity_argv[n++] = (char *)"--directory";
+            continue;
+        }
+        if (!lstrcmpW(argv_w[i], L"--multi"))
+        {
+            free(arg);
+            zenity_argv[n++] = (char *)"--multiple";
+            zenity_argv[n++] = (char *)"--separator=\\n";
+            continue;
+        }
+        if (!lstrcmpW(argv_w[i], L"--filename"))
+        {
+            free(arg);
+            i++;
+            if (i >= argc) break;
+            /* Convert Windows path to Unix path if needed */
+            char *filename = strdup_utf8(argv_w[i]);
+            if (!filename) continue;
+
+            if (is_windows_path(filename))
+            {
+                char *unix_path = win_to_unix_path(argv_w[i]);
+                if (unix_path)
+                {
+                    free(filename);
+                    zenity_argv[n++] = (char *)"--filename";
+                    zenity_argv[n++] = unix_path;
+                    /* Don't free unix_path - it's in zenity_argv now */
+                    continue;
+                }
+            }
+            zenity_argv[n++] = (char *)"--filename";
+            zenity_argv[n++] = filename;
+            continue;
+        }
+        if (!lstrcmpW(argv_w[i], L"--file-filter"))
+        {
+            free(arg);
+            i++;
+            if (i >= argc) break;
+            /* Convert semicolons to spaces in the pattern part (after |) */
+            char *filter = strdup_utf8(argv_w[i]);
+            if (!filter) continue;
+            char *pipe_pos = strchr(filter, '|');
+            if (pipe_pos) replace_semicolons_with_spaces(pipe_pos + 1);
+            zenity_argv[n++] = (char *)"--file-filter";
+            zenity_argv[n++] = filter;
+            continue;
+        }
+
+        /* Pass through unknown args */
+        zenity_argv[n++] = arg;
+    }
+    zenity_argv[n] = NULL;
+
+    result = run_zenity(zenity_argv);
+
+    /* Free allocated args (skip fixed strings) */
+    for (i = 2; i < n; i++)
+    {
+        if (zenity_argv[i] != (char *)"--save"
+            && zenity_argv[i] != (char *)"--confirm-overwrite"
+            && zenity_argv[i] != (char *)"--directory"
+            && zenity_argv[i] != (char *)"--multiple"
+            && zenity_argv[i] != (char *)"--separator=\\n"
+            && zenity_argv[i] != (char *)"--filename"
+            && zenity_argv[i] != (char *)"--file-filter")
+            free(zenity_argv[i]);
+    }
+
+    /* Prepare result path */
+    GetTempPathW(MAX_PATH, temp_path);
+    lstrcatW(temp_path, L"winefiledialog_result.txt");
+
+    if (result)
+    {
+        /* Convert Unix path to Windows path */
+        WCHAR *win_path = unix_to_win_path(result);
+        free(result);
+
+        HANDLE hFile = CreateFileW(temp_path, GENERIC_WRITE, 0, NULL,
+                                    CREATE_ALWAYS, FILE_ATTRIBUTE_NORMAL, NULL);
+        if (hFile != INVALID_HANDLE_VALUE)
+        {
+            DWORD written;
+            if (win_path)
+            {
+                /* Convert back to UTF-8 for the result file (comdlg32 reads UTF-8) */
+                char *utf8_result = strdup_utf8(win_path);
+                if (utf8_result)
+                {
+                    int len = strlen(utf8_result);
+                    WriteFile(hFile, utf8_result, len, &written, NULL);
+                    WriteFile(hFile, "\n", 1, &written, NULL);
+                    free(utf8_result);
+                }
+                free(win_path);
+            }
+            CloseHandle(hFile);
+        }
+        else
+        {
+            free(win_path);
+        }
+        return 0;
+    }
+    else
+    {
+        HANDLE hFile = CreateFileW(temp_path, GENERIC_WRITE, 0, NULL,
+                                    CREATE_ALWAYS, FILE_ATTRIBUTE_NORMAL, NULL);
+        if (hFile != INVALID_HANDLE_VALUE) CloseHandle(hFile);
+        return 1;
+    }
+}
