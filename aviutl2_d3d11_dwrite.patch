 /**************************************************************************
+ * Unix mount points
+ */
+static LPITEMIDLIST create_unix_mount_pidl(const char *mount_point)
+{
+    WCHAR mountW[MAX_PATH], *name_start;
+    int name_len_bytes, path_len_bytes;
+    int mount_len;
+    LPITEMIDLIST pidl;
+
+    mount_len = MultiByteToWideChar(CP_UTF8, 0, mount_point, -1, mountW, MAX_PATH);
+    if (mount_len <= 0) return NULL;
+
+    name_start = wcsrchr(mountW, L'/');
+    if (!name_start) name_start = mountW;
+    else name_start++;
+
+    name_len_bytes = (lstrlenW(name_start) + 1) * sizeof(WCHAR);
+    path_len_bytes = mount_len * sizeof(WCHAR);
+
+    pidl = SHAlloc(offsetof(SHITEMID, abID) + 1 + name_len_bytes + path_len_bytes + sizeof(WORD));
+    if (!pidl) return NULL;
+
+    pidl->mkid.cb = sizeof(pidl->mkid.cb) + 1 + name_len_bytes + path_len_bytes;
+    pidl->mkid.abID[0] = PT_UNIXMOUNT;
+    memcpy(pidl->mkid.abID + 1, name_start, name_len_bytes);
+    memcpy(pidl->mkid.abID + 1 + name_len_bytes, mountW, path_len_bytes);
+
+    return pidl;
+}
+
+static BOOL add_unix_mount_point(IEnumIDListImpl *list, const char *mount_point)
+{
+    LPITEMIDLIST pidl = create_unix_mount_pidl(mount_point);
+
+    if (!pidl) return TRUE;
+    return AddToEnumList(list, pidl);
+}
+
+static int is_pseudo_fs(const char *fstype)
+{
+    static const char *pseudo_fses[] = {
+        "proc", "sysfs", "tmpfs", "devtmpfs", "devpts", "cgroup", "cgroup2",
+        "pstore", "securityfs", "hugetlbfs", "configfs", "efivarfs", "bpf",
+        "debugfs", "tracefs", "selinuxfs", "autofs", "overlay", "fuse.gvfsd-fuse",
+        "fuse.portal", "fuse.gvfsd-metadata", "rpc_pipefs", "sunrpc",
+        "mqueue", "cpuset", "nsfs", "squashfs", "iso9660", "udf",
+        "ramfs", "fusectl", "efivarfs", NULL
+    };
+    int i;
+    for (i = 0; pseudo_fses[i]; i++)
+        if (strcmp(fstype, pseudo_fses[i]) == 0) return 1;
+    return 0;
+}
+
+static int is_system_mount(const char *mount_point)
+{
+    if (strcmp(mount_point, "/") == 0) return 1;
+    if (strcmp(mount_point, "/boot") == 0) return 1;
+    if (strcmp(mount_point, "/boot/efi") == 0) return 1;
+    if (strncmp(mount_point, "/snap/", 6) == 0) return 1;
+    if (strncmp(mount_point, "/var/lib/snapd/", 15) == 0) return 1;
+    if (strncmp(mount_point, "/run/", 5) == 0) return 1;
+    if (strncmp(mount_point, "/sys/", 5) == 0) return 1;
+    if (strncmp(mount_point, "/proc/", 6) == 0) return 1;
+    if (strncmp(mount_point, "/dev/", 5) == 0) return 1;
+    return 0;
+}
+
+static int is_network_fs(const char *fstype)
+{
+    static const char *network[] = {
+        "cifs", "smbfs", "nfs", "nfs3", "nfs4", NULL
+    };
+    int i;
+    for (i = 0; network[i]; i++)
+        if (!strcmp(fstype, network[i])) return 1;
+    return 0;
+}
+
+static void enumerate_unix_mounts(IEnumIDListImpl *list)
+{
+    FILE *f = fopen("/proc/mounts", "r");
+    char line[4096];
+    int count = 0;
+
+    if (!f) return;
+
+    while (fgets(line, sizeof(line), f))
+    {
+char device[256], mount_point[4096], fstype[64], options[256];
+
+            if (sscanf(line, "%255s %4095s %63s %255s %*d %*d",
+                       device, mount_point, fstype, options) < 3)
+                continue;
+
+            if (is_pseudo_fs(fstype)) continue;
+            if (is_system_mount(mount_point)) continue;
+
+            if (!is_network_fs(fstype) && _access(mount_point, 0) != 0)
+                continue;
+
+        if (!add_unix_mount_point(list, mount_point))
+            break;
+        count++;
+    }
+    fclose(f);
+    TRACE("Added %d Linux mount points.\n", count);
+}
