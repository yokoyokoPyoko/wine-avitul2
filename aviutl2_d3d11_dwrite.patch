+/* Try native file dialog (zenity) for GetOpenFileNameW/GetSaveFileNameW.
+ * Returns TRUE on success, FALSE on cancel/error, -1 to fall back to built-in dialog. */
+static int try_native_getopenfilename(OPENFILENAMEW *ofn, BOOL is_save)
+{
+    static BOOL checked = FALSE;
+    static BOOL use_native = FALSE;
+    WCHAR cmdline[4096], exe_path[MAX_PATH], temp_path[MAX_PATH], result_path[MAX_PATH];
+    PROCESS_INFORMATION pi;
+    STARTUPINFOW si;
+    DWORD exit_code, read_len;
+    HANDLE hFile;
+    char buf[4096];
+    WCHAR resultW[MAX_PATH];
+    int result_len;
+    UINT i;
+
+    if (!checked)
+    {
+        const char *env = getenv("WINE_NATIVE_FILE_DIALOG");
+        if (env && (!strcmp(env, "0") || !strcmp(env, "false")))
+            use_native = FALSE;
+        else
+            use_native = TRUE;
+        checked = TRUE;
+    }
+    if (!use_native) return -1;
+
+    FIXME("Using native file dialog\n");
+
+    /* Build command line */
+    GetSystemDirectoryW(exe_path, MAX_PATH);
+    lstrcatW(exe_path, L"\\winefiledialog.exe");
+
+    lstrcpyW(cmdline, L"\"");
+    lstrcatW(cmdline, exe_path);
+    lstrcatW(cmdline, L"\"");
+
+    if (is_save)
+        lstrcatW(cmdline, L" --save");
+    else
+        lstrcatW(cmdline, L" --open");
+
+    if (ofn->lpstrTitle && ofn->lpstrTitle[0])
+    {
+        lstrcatW(cmdline, L" --title \"");
+        lstrcatW(cmdline, ofn->lpstrTitle);
+        lstrcatW(cmdline, L"\"");
+    }
+
+    /* Initial dir: prefer lpstrInitialDir, else directory part of lpstrFile */
+    if (ofn->lpstrInitialDir && ofn->lpstrInitialDir[0])
+    {
+        lstrcatW(cmdline, L" --filename \"");
+        lstrcatW(cmdline, ofn->lpstrInitialDir);
+        lstrcatW(cmdline, L"\"");
+    }
+
+    /* Convert lpstrFilter (double-null pairs) to --file-filter args */
+    if (ofn->lpstrFilter)
+    {
+        const WCHAR *fp = ofn->lpstrFilter;
+        while (*fp)
+        {
+            const WCHAR *name = fp;
+            while (*fp) fp++;
+            fp++;
+            const WCHAR *spec = fp;
+            while (*fp) fp++;
+            fp++;
+
+            /* Build: --file-filter "name|spec" */
+            lstrcatW(cmdline, L" --file-filter \"");
+            lstrcatW(cmdline, name);
+            lstrcatW(cmdline, L"|");
+            lstrcatW(cmdline, spec);
+            lstrcatW(cmdline, L"\"");
+        }
+    }
+
+    TRACE("Launching: %s\n", wine_dbgstr_w(cmdline));
+
+    /* Result file path */
+    GetTempPathW(MAX_PATH, temp_path);
+    lstrcpyW(result_path, temp_path);
+    lstrcatW(result_path, L"winefiledialog_result.txt");
+    DeleteFileW(result_path);
+
+    /* Launch */
+    memset(&si, 0, sizeof(si));
+    si.cb = sizeof(si);
+    if (!CreateProcessW(exe_path, cmdline, NULL, NULL, FALSE, 0, NULL, NULL, &si, &pi))
+    {
+        ERR("Failed to launch winefiledialog.exe, error=%u\n", (unsigned)GetLastError());
+        return -1;
+    }
+    CloseHandle(pi.hThread);
+    WaitForSingleObject(pi.hProcess, 30000);
+    GetExitCodeProcess(pi.hProcess, &exit_code);
+    CloseHandle(pi.hProcess);
+
+    /* Read result */
+    hFile = CreateFileW(result_path, GENERIC_READ, FILE_SHARE_READ, NULL,
+                        OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, NULL);
+    if (hFile == INVALID_HANDLE_VALUE)
+        return FALSE;
+
+    ReadFile(hFile, buf, sizeof(buf) - 1, &read_len, NULL);
+    buf[read_len] = '\0';
+    CloseHandle(hFile);
+    DeleteFileW(result_path);
+
+    /* Trim trailing newline */
+    while (read_len > 0 && (buf[read_len-1] == '\n' || buf[read_len-1] == '\r'))
+        buf[--read_len] = '\0';
+    if (read_len == 0) return FALSE;
+
+    /* Convert to wide char */
+    result_len = MultiByteToWideChar(CP_UTF8, 0, buf, read_len + 1, resultW, MAX_PATH);
+    if (result_len <= 0 || result_len > ofn->nMaxFile)
+    {
+        COMDLG32_SetCommDlgExtendedError(FNERR_BUFFERTOOSMALL);
+        return FALSE;
+    }
+
+    /* Copy result to lpstrFile */
+    lstrcpyW(ofn->lpstrFile, resultW);
+
+    /* Set nFileOffset: find last backslash */
+    for (i = 0; resultW[i]; i++)
+        if (resultW[i] == '\\') ofn->nFileOffset = i + 1;
+    if (ofn->nFileOffset == 0) ofn->nFileOffset = 0;
+
+    /* Set nFileExtension: find last dot after offset */
+    ofn->nFileExtension = 0;
+    for (i = ofn->nFileOffset; resultW[i]; i++)
+        if (resultW[i] == '.') ofn->nFileExtension = i;
+
+    return TRUE;
+}
