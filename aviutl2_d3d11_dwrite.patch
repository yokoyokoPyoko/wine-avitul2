+    DeleteFileW(result_path);
+
+    /* Launch winefiledialog.exe */
+    memset(&si, 0, sizeof(si));
+    si.cb = sizeof(si);
+    if (!CreateProcessW(exe_path, cmdline, NULL, NULL, FALSE, 0, NULL, NULL, &si, &pi))
+    {
+        WARN("Failed to launch winefiledialog.exe (error %lu)\n", GetLastError());
+        return S_FALSE;
+    }
+
+    WaitForSingleObject(pi.hProcess, INFINITE);
+    GetExitCodeProcess(pi.hProcess, &exit_code);
+    CloseHandle(pi.hThread);
+    CloseHandle(pi.hProcess);
+
+    if (exit_code != 0)
+    {
+        TRACE("winefiledialog.exe cancelled (exit %lu)\n", exit_code);
+        return HRESULT_FROM_WIN32(ERROR_CANCELLED);
+    }
+
+    /* Read result file */
+    hFile = CreateFileW(result_path, GENERIC_READ, FILE_SHARE_READ, NULL,
+                        OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, NULL);
+    if (hFile == INVALID_HANDLE_VALUE)
+    {
+        WARN("Failed to open result file (error %lu)\n", GetLastError());
+        return HRESULT_FROM_WIN32(ERROR_CANCELLED);
+    }
+
+    if (!ReadFile(hFile, buf, sizeof(buf) - 1, &read_len, NULL) || read_len == 0)
+    {
+        CloseHandle(hFile);
+        return HRESULT_FROM_WIN32(ERROR_CANCELLED);
+    }
+    CloseHandle(hFile);
+    buf[read_len] = '\0';
+
+    /* Strip trailing newline */
+    while (read_len > 0 && (buf[read_len - 1] == '\n' || buf[read_len - 1] == '\r'))
+        buf[--read_len] = '\0';
+
+    if (read_len == 0)
+    {
+        TRACE("Empty result (cancelled)\n");
+        return HRESULT_FROM_WIN32(ERROR_CANCELLED);
+    }
+
+    TRACE("Selected path: %s\n", wine_dbgstr_a(buf));
+
+    /* Convert UTF-8 result to WCHAR */
+    if (!MultiByteToWideChar(CP_UTF8, 0, buf, -1, pathW, ARRAY_SIZE(pathW)))
+    {
+        ERR("Failed to convert result to wide chars\n");
+        return E_FAIL;
+    }
+
+    /* Create IShellItem from path */
+    hr = SHCreateItemFromParsingName(pathW, NULL, &IID_IShellItem, (void**)&psi);
+    if (FAILED(hr))
+    {
+        ERR("SHCreateItemFromParsingName failed: %08lx\n", hr);
+        return E_FAIL;
+    }
+
+    /* Wrap in IShellItemArray */
+    hr = SHCreateShellItemArrayFromShellItem(psi, &IID_IShellItemArray, (void**)&psia);
+    IShellItem_Release(psi);
+    if (FAILED(hr))
+    {
+        ERR("SHCreateShellItemArrayFromShellItem failed: %08lx\n", hr);
+        return E_FAIL;
+    }
+
+    /* Store result */
+    This->psia_results = psia;
+
+    /* Notify FileOk event */
+    if (FAILED(hr = events_OnFileOk(This)))
+    {
+        IShellItemArray_Release(This->psia_results);
+        This->psia_results = NULL;
+        return hr;
+    }
+
+    return S_OK;
+}
+
 static HRESULT WINAPI IFileDialog2_fnShow(IFileDialog2 *iface, HWND hwndOwner)
 {
     FileDialogImpl *This = impl_from_IFileDialog2(iface);
+    HRESULT hr;
     TRACE("%p (%p)\n", iface, hwndOwner);
 
