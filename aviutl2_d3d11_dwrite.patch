+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+#include <sys/wait.h>
+#include <windows.h>
+
+static int try_open(const char *program, char *const argv[])
+{
+    pid_t pid = fork();
+    if (pid == -1) return -1;
+    if (pid == 0)
+    {
+        execvp(program, argv);
+        _exit(1);
+    }
+    int status;
+    waitpid(pid, &status, 0);
+    return (WIFEXITED(status) && WEXITSTATUS(status) == 0) ? 0 : -1;
+}
+
+int wmain(int argc, WCHAR *argv_w[])
+{
+    WCHAR *folder_path = NULL;
+    WCHAR *select_path = NULL;
+    int i;
+
+    if (argc < 2) return 1;
+
+    folder_path = argv_w[1];
+
+    for (i = 2; i + 1 < argc; i++)
+    {
+        if (!lstrcmpW(argv_w[i], L"--select"))
+        {
+            select_path = argv_w[i + 1];
+            break;
+        }
+    }
+
+    if (select_path)
+    {
+        char *unix_select = wine_get_unix_file_name(select_path);
+        if (unix_select)
+        {
+            char *nautilus_argv[] = {"nautilus", "--select", unix_select, NULL};
+            if (try_open("nautilus", nautilus_argv) == 0)
+            {
+                HeapFree(GetProcessHeap(), 0, unix_select);
+                return 0;
+            }
+            HeapFree(GetProcessHeap(), 0, unix_select);
+        }
+    }
+
+    char *unix_folder = wine_get_unix_file_name(folder_path);
+    if (!unix_folder) return 1;
+
+    char *xdg_argv[] = {"xdg-open", unix_folder, NULL};
+    if (try_open("xdg-open", xdg_argv) == 0)
+    {
+        HeapFree(GetProcessHeap(), 0, unix_folder);
+        return 0;
+    }
+
+    HeapFree(GetProcessHeap(), 0, unix_folder);
+    return 1;
+}
