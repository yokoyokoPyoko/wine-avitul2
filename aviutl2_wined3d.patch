+/* [AviUtl2 v12.7-STAGING] G8R8_G8B8_UNORM packed 4:2:2 YUV upload converter.
+ * D3D11 samples G8R8_G8B8_UNORM as (.r=Cb, .g=Y, .b=Cr, .a=Y1).
+ * GL_RGBA8 stores bytes in order: byte0→.r, byte1→.g, byte2→.b, byte3→.a.
+ * Source macropixel layout: [Y0, Cb, Y1, Cr] (4 bytes = 2 pixels).
+ * We rearrange to: pixel0=[Cb, Y0, Cr, 255], pixel1=[Cb, Y1, Cr, 255]
+ * giving GL .r=Cb ✓, .g=Y ✓, .b=Cr ✓, .a=1 for both pixels. */
+static void convert_g8r8_g8b8_unorm(const BYTE *src, BYTE *dst, UINT src_row_pitch, UINT src_slice_pitch,
+        UINT dst_row_pitch, UINT dst_slice_pitch, UINT width, UINT height, UINT depth)
+{
+    unsigned int x, y, z;
+
+    for (z = 0; z < depth; z++)
+    {
+        for (y = 0; y < height; y++)
+        {
+            const BYTE *src_row = src + z * src_slice_pitch + y * src_row_pitch;
+            BYTE *dst_row = dst + z * dst_slice_pitch + y * dst_row_pitch;
+
+            for (x = 0; x < width; x += 2)
+            {
+                BYTE y0 = src_row[2 * x];      /* G = Y0 luma */
+                BYTE cb = src_row[2 * x + 1];  /* R = Cb chroma */
+                BYTE y1 = src_row[2 * x + 2];  /* G = Y1 luma */
+                BYTE cr = src_row[2 * x + 3];  /* B = Cr chroma */
+
+                /* pixel x+0: R=Cb, G=Y0, B=Cr, A=255 */
+                dst_row[4 * x]     = cb;
+                dst_row[4 * x + 1] = y0;
+                dst_row[4 * x + 2] = cr;
+                dst_row[4 * x + 3] = 255;
+                /* pixel x+1: R=Cb, G=Y1, B=Cr, A=255 */
+                dst_row[4 * x + 4] = cb;
+                dst_row[4 * x + 5] = y1;
+                dst_row[4 * x + 6] = cr;
+                dst_row[4 * x + 7] = 255;
+            }
+        }
+    }
+}
